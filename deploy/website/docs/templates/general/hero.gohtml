<p class="inline-flex w-full items-center gap-2 font-mono text-[13px] font-extrabold uppercase leading-6 tracking-wide text-emerald-300"><span class="text-sky-300" aria-hidden="true">{{ .PromptFace }}</span>{{ .Section }}</p>
<h1 class="max-w-5xl text-balance text-5xl font-black leading-tight text-slate-50 max-[700px]:text-4xl">{{ .Title }}</h1>
<p class="max-w-5xl text-lg leading-8 text-slate-300">{{ .Description }}</p>

