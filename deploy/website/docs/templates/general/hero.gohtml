<p class="inline-flex w-full items-center gap-2 font-mono text-sm font-extrabold uppercase leading-6 tracking-wide text-slate-300"><span class="text-sky-400" aria-hidden="true">{{ .PromptFace }}</span>{{ .Section }}</p>
<h1 class="max-w-4xl text-balance text-4xl font-extrabold leading-tight text-slate-50 max-[700px]:text-3xl">{{ .Title }}</h1>
<p class="max-w-3xl text-base leading-7 text-slate-300">{{ .Description }}</p>

