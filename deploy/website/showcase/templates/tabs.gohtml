{{/*
@dot donseba/go-webthings-docs/internal/showcase.TabsPage
*/}}
<section class="grid gap-5">
    <header class="grid max-w-3xl gap-2.5">
        <span class="text-[13px] font-extrabold uppercase text-teal-900">Selected partialren</span>
        <h1 class="text-3xl font-extrabold leading-tight text-stone-950">{{ .Title }}</h1>
        <p class="leading-7 text-stone-600">Tabs are just selected partials. Each tab click sends <code class="rounded bg-stone-100 px-1.5 py-0.5 font-mono text-sm text-stone-900">{{ selectionHeader }}</code>, and the server renders the selected partial into the same panel.</p>
    </header>

    <div class="showcase-tabs grid gap-2">
        <div class="showcase-tab-list flex flex-wrap items-center gap-2" role="tablist">
            {{ range .Tabs }}
                <button
                    role="tab"
                    aria-selected="{{ if selectionIs .Key }}true{{ else }}false{{ end }}"
                    class="showcase-tab {{ if selectionIs .Key }}active{{ end }} inline-flex min-h-9 cursor-pointer items-center border px-3 py-2 text-sm font-bold"
                    hx-get="/tabs"
                    hx-target="#content"
                    hx-headers='{"{{ selectionHeader }}":"{{ .Key }}"}'>
                    {{ .Label }}
                </button>
            {{ end }}
        </div>

        <div class="showcase-tab-panel border border-stone-300 bg-white p-4" role="tabpanel">
            {{ selection }}
        </div>
    </div>

    <article class="grid gap-2 rounded-lg border border-stone-300 bg-white p-4">
        <h2 class="text-lg font-bold text-stone-950">Same primitive, different UI</h2>
        <p class="leading-7 text-stone-600">The tabs use the same selection mechanism as the selection page. The active state is derived from the current request header.</p>
    </article>

    <article class="grid gap-4 rounded-lg border border-stone-300 bg-white p-4">
        <h2 class="text-lg font-bold text-stone-950">Server setup</h2>
        <pre class="max-w-full overflow-hidden whitespace-pre-wrap break-words rounded-md border border-stone-300 bg-stone-100 p-3"><code class="block bg-transparent p-0 font-mono text-[13px] leading-6 text-stone-950">selection.WithSelectMap(content, "overview", map[string]*partial.Partial{
    "overview": overview,
    "activity": activity,
    "settings": settings,
    "failing": failing,
})</code></pre>
    </article>

    <article class="grid gap-4 rounded-lg border border-stone-300 bg-white p-4">
        <h2 class="text-lg font-bold text-stone-950">Template usage</h2>
        <pre class="max-w-full overflow-hidden whitespace-pre-wrap break-words rounded-md border border-stone-300 bg-stone-100 p-3"><code class="block bg-transparent p-0 font-mono text-[13px] leading-6 text-stone-950">&lt;button hx-get="/tabs"
        hx-target="#content"
        hx-headers='{"{{ selectionHeader }}":"overview"}'&gt;
    Overview
&lt;/button&gt;</code></pre>
    </article>
</section>
