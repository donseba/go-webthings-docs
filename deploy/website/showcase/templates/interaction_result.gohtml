{{/*
@dot donseba/go-webthings-docs/internal/showcase.InteractionResult
*/}}
<div id="{{ .ID }}" class="-mx-4 mt-auto grid gap-2 border-t border-cyan-400/50 bg-[#0b1f3a] p-4">
    <span class="border-b border-cyan-400/50 pb-2 text-[13px] font-black text-[#79ff8b]">{{ .Label }}</span>
    <h3 class="text-lg font-black leading-tight text-white">{{ .Message }}</h3>
    <p class="text-sm font-black text-sky-100">Rendered at {{ .Time }}</p>
</div>
