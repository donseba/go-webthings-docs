{{/*
@dot github.com/donseba/go-partial/examples/showcase.SelectionPanel
*/}}
<div>
    <h2 class="text-lg font-bold text-stone-950">{{ .Title }}</h2>
    <p class="leading-7 text-stone-600">This is the default selected partial. It is rendered through <code class="rounded bg-stone-100 px-1.5 py-0.5 font-mono text-sm text-stone-900">{{ "{{ selection }}" }}</code>.</p>
</div>
