{{ flash }}
<div class="grid gap-2 border border-cyan-400/60 border-l-4 border-l-cyan-400/80 bg-[#071226] p-3.5 text-white grid-cols-[1fr_auto]">
    <strong>{{ .Row.Name }}</strong>
    <span>{{ .Row.Status }}</span>
    <small>Loaded at {{ .RenderedAt }}</small>
</div>
