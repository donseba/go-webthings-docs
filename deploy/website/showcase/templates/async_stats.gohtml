{{/*
@dot github.com/donseba/go-partial/examples/showcase.AsyncStats
*/}}
<div class="grid gap-2 border border-stone-300 border-l-4 border-l-teal-700 bg-teal-50/40 p-3.5 text-stone-950">
    <span class="inline-flex rounded-full border border-teal-200 px-2.5 py-1 text-[13px] font-bold text-teal-900">Loaded</span>
    <h3 class="text-lg font-bold text-stone-950">Stats rendered at {{ .RenderedAt }}</h3>
    <p class="leading-7 text-stone-600">{{ .Rows }} rows are available in the showcase data set.</p>
</div>
