{{/*
@dot donseba/go-webthings-docs/internal/showcase.AsyncStats
*/}}
<div class="grid gap-2 border border-cyan-400/60 border-l-4 border-l-cyan-400/80 bg-[#071226] p-3.5 text-white">
    <span class="inline-flex border border-cyan-400/70 px-2.5 py-1 text-[13px] font-bold text-[#79ff8b]">Loaded</span>
    <h3 class="text-lg font-bold text-white">Stats rendered at {{ .RenderedAt }}</h3>
    <p class="leading-7 text-sky-100">{{ .Rows }} rows are available in the showcase data set.</p>
</div>
