<section id="rickroll" class="grid gap-3 border border-cyan-400/60 bg-[#020817] p-4">
    <h2 class="text-lg font-bold text-white">150 rows reached</h2>
    <p class="leading-7 text-sky-100">The server has completed its very serious infinite-scroll duty.</p>
