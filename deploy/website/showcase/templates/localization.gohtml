{{/*
@dot github.com/donseba/go-partial/examples/showcase.LocalizationPage
*/}}
<section class="grid gap-5">
    <header class="grid max-w-3xl gap-2.5">
        <span class="text-[13px] font-extrabold uppercase text-teal-900">Localization</span>
        <h1 class="text-3xl font-extrabold leading-tight text-stone-950">{{ tl localizer "title" }}</h1>
        <p class="leading-7 text-stone-600">{{ tl localizer "intro" }}</p>
    </header>

    <div class="rounded-lg border border-stone-300 bg-white p-4 grid gap-3.5">
        <div class="flex flex-wrap gap-2" aria-label="Locale switcher">
            {{ range .Locales }}
                <button
                    type="button"
                    class="{{ if eq $.Locale . }}inline-flex min-h-9 cursor-pointer items-center rounded-md border border-teal-700 bg-teal-700 px-3 py-2 text-sm font-bold text-white{{ else }}inline-flex min-h-9 cursor-pointer items-center rounded-md border border-stone-300 bg-white px-3 py-2 text-sm text-stone-950 hover:border-teal-700 hover:text-teal-900{{ end }}"
                    hx-get="/localization?locale={{ . }}"
                    hx-target="#content"
                    hx-push-url="true">
                    {{ . }}
                </button>
            {{ end }}
        </div>

        <article class="grid gap-3.5">
            <span class="inline-flex rounded-full border border-teal-200 px-2.5 py-1 text-[13px] font-bold text-teal-900">{{ tl localizer "active" }}: {{ locale }}</span>
            <h2 class="text-lg font-bold text-stone-950">{{ tl localizer "checkout" }}</h2>
            <dl class="grid grid-cols-[140px_minmax(0,1fr)] gap-x-4 gap-y-2.5 rounded-lg border border-stone-300 bg-white p-4">
                <dt>{{ tl localizer "total" }}</dt>
                <dd>EUR 42.75</dd>
                <dt>{{ tl localizer "delivery" }}</dt>
                <dd>{{ tl localizer "status" }}</dd>
                <dt>tn</dt>
                <dd>{{ tn localizer "oneMessage" "manyMessage" .Count .Count }}</dd>
                <dt>ctl</dt>
                <dd>{{ ctl localizer "button" "save" }}</dd>
            </dl>
            <p class="leading-7 text-stone-600">{{ tl localizer "explanation" }}</p>
        </article>
    </div>

    <article class="grid gap-2 rounded-lg border border-stone-300 bg-white p-4">
        <h2 class="text-lg font-bold text-stone-950">Bring your own translator</h2>
        <p class="leading-7 text-stone-600">The package only requires <code class="rounded bg-stone-100 px-1.5 py-0.5 font-mono text-sm text-stone-900">GetLocale()</code>. Translation behavior is linked through template functions, so the localizer can stay focused on the active locale.</p>
    </article>

    <article class="grid gap-4 rounded-lg border border-stone-300 bg-white p-4">
        <h2 class="text-lg font-bold text-stone-950">Server setup</h2>
        <pre class="max-w-full overflow-hidden whitespace-pre-wrap break-words rounded-md border border-stone-300 bg-stone-100 p-3"><code class="block bg-transparent p-0 font-mono text-[13px] leading-6 text-stone-950">ctx := localization.WithLocalizer(r.Context(), localizer)
partial.Write(ctx, w, r, content)</code></pre>
    </article>

    <article class="grid gap-4 rounded-lg border border-stone-300 bg-white p-4">
        <h2 class="text-lg font-bold text-stone-950">Template usage</h2>
        <pre class="max-w-full overflow-hidden whitespace-pre-wrap break-words rounded-md border border-stone-300 bg-stone-100 p-3"><code class="block bg-transparent p-0 font-mono text-[13px] leading-6 text-stone-950">&lt;h1&gt;{{ "{{ tl localizer \"title\" }}" }}&lt;/h1&gt;
&lt;p&gt;{{ "{{ tn localizer \"oneMessage\" \"manyMessage\" .Count .Count }}" }}&lt;/p&gt;
&lt;button&gt;{{ "{{ ctl localizer \"button\" \"save\" }}" }}&lt;/button&gt;</code></pre>
    </article>
</section>
