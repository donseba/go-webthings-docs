{{/* @dot donseba/go-webthings-docs/internal/website.PageData */}}
<div class="main-marquee" aria-label="Site notice">
    <span class="main-marquee-label">LATEST NEWS</span>
    <span id="main-bulletin" class="main-bulletin-slot" hx-get="/bulletin" hx-trigger="load delay:8s, every 8s" hx-swap="innerHTML">
        <span class="main-bulletin-line">{{ .Bulletin }}</span>
    </span>
    <span class="main-bulletin-timer" aria-hidden="true"><span class="main-bulletin-timer-fill"></span></span>
</div>
